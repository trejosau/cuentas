# Node
TZ=UTC
PORT=3334
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway
DB_SSL=false

# Internal communication
INTERNAL_API_TOKEN=change-me

# Container identity
CONTAINER_CODE=example1-backend
CONTAINER_NAME=Contenedor 01
CONTAINER_BASE_URL=http://${HOST}:${PORT}
CONTAINER_MAX_ACCOUNTS=3
SYNC_INTERVAL_MINUTES=30
HEARTBEAT_INTERVAL_SECONDS=60
TOKEN_REFRESH_WINDOW_SECONDS=180

# HMC upstream
HMC_BASE_URL=https://mxg.ht-kook.com
HMC_ORIGIN=https://www.hmc-mex.com
HMC_REFERER=https://www.hmc-mex.com/
HMC_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36 Edg/146.0.0.0

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
